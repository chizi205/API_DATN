// prisma/schema.prisma
// Loyalty Management System - Prisma Schema
// Chuyển đổi từ script PostgreSQL đã cải tiến

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:0915051590@localhost:5432/QuanLyKhachHangThanThiet?schema=public"
}

// ===================== ENUMS =====================

enum InvoiceStatus {
  pending
  paid
  cancelled
  refunded
}

enum PaymentMethod {
  cash
  card
  transfer
  e_wallet
  other
}

enum PointTransactionType {
  earn
  redeem
  adjust
  expire
  bonus
  refund
}

enum DiscountType {
  percent
  fixed
}

enum ReservationStatus {
  pending
  confirmed
  seated
  completed
  cancelled
  no_show
}

enum ActorType {
  employee
  member
  system
  admin
}

enum UserType {
  member
  employee
}

// ===================== MODELS =====================

model Branch {
  id         BigInt   @id @default(autoincrement())
  name       String   @db.VarChar(255)
  address    String?  @db.Text
  phone      String?  @db.VarChar(20)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employees          Employee[]
  invoices           Invoice[]
  reservations       Reservation[]
  tables             Table[]
  point_transactions PointTransaction[]

  @@index([name], map: "idx_branches_name")
}

model MembershipTier {
  id               BigInt   @id @default(autoincrement())
  tier_name        String   @unique @db.VarChar(50)
  min_points       BigInt   @default(0)
  point_multiplier Decimal  @default(1.00) @db.Decimal(5, 2)
  benefits         String?  @db.Text
  color_code       String?  @db.VarChar(20)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  members           Member[]
  tier_history_from TierHistory[] @relation("OldTier")
  tier_history_to   TierHistory[] @relation("NewTier")
}

model PointConfig {
  id           BigInt   @id @default(autoincrement())
  spend_amount Decimal  @db.Decimal(12, 2)
  earn_points  Int
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  products Product[]
}

model Employee {
  id            BigInt   @id @default(autoincrement())
  employee_code String   @unique @db.VarChar(50)
  full_name     String   @db.VarChar(255)
  email         String?  @db.VarChar(255)
  role          String?  @db.VarChar(50)
  branch_id     BigInt?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  branch             Branch?            @relation(fields: [branch_id], references: [id])
  invoices           Invoice[]
  vouchers           Voucher[]
  point_transactions PointTransaction[]
  tier_history       TierHistory[]
  reservations       Reservation[]
  profiles           Profile[] // ← Thêm dòng này

  // Đã xóa dòng: audit_logs AuditLog[]
  auditLogs AuditLog[]

  @@index([branch_id], map: "idx_employees_branch")
  @@index([employee_code], map: "idx_employees_code")
}

model Member {
  id                       BigInt    @id @default(autoincrement())
  phone_number             String    @unique @db.VarChar(20)
  full_name                String?   @db.VarChar(255)
  email                    String?   @db.VarChar(255)
  date_of_birth            DateTime? @db.Date
  current_points           Int       @default(0)
  total_accumulated_points BigInt    @default(0)
  tier_id                  BigInt?
  barcode                  String?   @unique @db.VarChar(50)
  last_activity_date       DateTime? @db.Date
  is_active                Boolean   @default(true)
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  tier               MembershipTier?    @relation(fields: [tier_id], references: [id])
  invoices           Invoice[]
  member_vouchers    MemberVoucher[]
  point_transactions PointTransaction[]
  tier_history       TierHistory[]
  notifications      Notification[]
  profiles           Profile[]
  reservations       Reservation[]

  @@index([phone_number], map: "idx_members_phone")
  @@index([tier_id], map: "idx_members_tier")
  @@index([barcode], map: "idx_members_barcode")
}

model Product {
  id          BigInt   @id @default(autoincrement())
  category_id BigInt?
  name        String   @db.VarChar(255)
  description String?  @db.Text
  base_price  Decimal  @db.Decimal(12, 2)
  image_url   String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category        Category?       @relation(fields: [category_id], references: [id])
  invoice_details InvoiceDetail[]

  @@index([category_id], map: "idx_products_category")
}

model Voucher {
  id                   BigInt       @id @default(autoincrement())
  code                 String       @unique @db.VarChar(50)
  title                String       @db.VarChar(255)
  description          String?      @db.Text
  point_cost           Int
  discount_type        DiscountType
  discount_value       Decimal      @db.Decimal(12, 2)
  max_discount         Decimal?     @db.Decimal(12, 2)
  min_order_value      Decimal?     @default(0) @db.Decimal(12, 2)
  stock_quantity       Int          @default(0)
  max_usage_per_member Int          @default(1)
  applicable_tiers     String?      @db.VarChar(100)
  valid_from           DateTime?    @db.Date
  valid_to             DateTime?    @db.Date
  expiry_days          Int?
  is_active            Boolean      @default(true)
  created_by           BigInt?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  created_by_employee Employee?       @relation(fields: [created_by], references: [id])
  member_vouchers     MemberVoucher[]

  @@index([code], map: "idx_vouchers_code")
  @@index([is_active], map: "idx_vouchers_active")
}

model Invoice {
  id                        BigInt         @id @default(autoincrement())
  invoice_code              String         @unique @db.VarChar(50)
  employee_id               BigInt?
  branch_id                 BigInt?
  member_id                 BigInt?
  applied_member_voucher_id BigInt?
  sub_total                 Decimal        @default(0) @db.Decimal(12, 2)
  discount_amount           Decimal        @default(0) @db.Decimal(12, 2)
  voucher_discount          Decimal        @default(0) @db.Decimal(12, 2)
  tax_amount                Decimal        @default(0) @db.Decimal(12, 2)
  service_charge            Decimal        @default(0) @db.Decimal(12, 2)
  final_amount              Decimal        @default(0) @db.Decimal(12, 2)
  points_earned             Int            @default(0)
  points_multiplier         Decimal        @default(1.00) @db.Decimal(5, 2)
  payment_method            PaymentMethod?
  status                    InvoiceStatus  @default(pending)
  table_number              String?        @db.VarChar(20)
  created_at                DateTime       @default(now())
  updated_at                DateTime       @updatedAt

  employee               Employee?       @relation(fields: [employee_id], references: [id])
  branch                 Branch?         @relation(fields: [branch_id], references: [id])
  member                 Member?         @relation(fields: [member_id], references: [id])
  applied_member_voucher MemberVoucher?  @relation("AppliedVoucher", fields: [applied_member_voucher_id], references: [id])
  invoice_details        InvoiceDetail[]
  member_vouchers_used   MemberVoucher[] @relation("UsedInInvoice")

  @@index([invoice_code], map: "idx_invoices_code")
  @@index([branch_id, created_at], map: "idx_invoices_branch_date")
  @@index([member_id, created_at], map: "idx_invoices_member_date")
  @@index([status], map: "idx_invoices_status")
}

model InvoiceDetail {
  id           BigInt   @id @default(autoincrement())
  invoice_id   BigInt
  product_id   BigInt?
  product_name String?  @db.VarChar(255)
  quantity     Int
  unit_price   Decimal  @db.Decimal(12, 2)
  total_price  Decimal  @db.Decimal(12, 2)
  created_at   DateTime @default(now())

  invoice Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [product_id], references: [id])

  @@index([invoice_id], map: "idx_invoice_details_invoice")
}

model MemberVoucher {
  id              BigInt    @id @default(autoincrement())
  member_id       BigInt
  voucher_id      BigInt
  voucher_code    String?   @db.VarChar(50)
  status          String    @default("active") @db.VarChar(20)
  points_spent    Int?
  acquired_at     DateTime  @default(now())
  expiry_date     DateTime? @db.Date
  used_at         DateTime?
  used_invoice_id BigInt?
  created_at      DateTime  @default(now())

  member           Member    @relation(fields: [member_id], references: [id])
  voucher          Voucher   @relation(fields: [voucher_id], references: [id])
  used_invoice     Invoice?  @relation("UsedInInvoice", fields: [used_invoice_id], references: [id])
  applied_invoices Invoice[] @relation("AppliedVoucher")

  @@index([member_id], map: "idx_member_vouchers_member")
  @@index([status], map: "idx_member_vouchers_status")
}

model PointTransaction {
  id                 BigInt               @id @default(autoincrement())
  member_id          BigInt
  branch_id          BigInt?
  transaction_type   PointTransactionType
  points             Int
  multiplier_applied Decimal              @default(1.00) @db.Decimal(5, 2)
  reference_type     String?              @db.VarChar(50)
  reference_id       BigInt?
  description        String?              @db.Text
  created_by         BigInt?
  created_at         DateTime             @default(now())

  member              Member    @relation(fields: [member_id], references: [id])
  branch              Branch?   @relation(fields: [branch_id], references: [id])
  created_by_employee Employee? @relation(fields: [created_by], references: [id])

  @@index([member_id, created_at], map: "idx_point_trans_member_date")
  @@index([transaction_type], map: "idx_point_trans_type")
  @@index([reference_type, reference_id], map: "idx_point_trans_reference")
}

model TierHistory {
  id                     BigInt   @id @default(autoincrement())
  member_id              BigInt
  old_tier_id            BigInt?
  new_tier_id            BigInt?
  change_type            String?  @db.VarChar(20)
  reason                 String?  @db.Text
  old_accumulated_points BigInt?
  new_accumulated_points BigInt?
  changed_by             BigInt?
  changed_by_type        String?  @db.VarChar(20)
  reference_id           String?  @db.VarChar(100)
  notes                  String?  @db.Text
  created_at             DateTime @default(now())

  member              Member          @relation(fields: [member_id], references: [id])
  old_tier            MembershipTier? @relation("OldTier", fields: [old_tier_id], references: [id])
  new_tier            MembershipTier? @relation("NewTier", fields: [new_tier_id], references: [id])
  changed_by_employee Employee?       @relation(fields: [changed_by], references: [id])

  @@index([member_id], map: "idx_tier_history_member")
}

model AuditLog {
  id          BigInt    @id @default(autoincrement())
  actor_type  ActorType
  actor_id    BigInt?
  action      String    @db.VarChar(100)
  table_name  String    @db.VarChar(100)
  record_id   BigInt
  old_values  Json?
  new_values  Json?
  description String?   @db.Text
  ip_address  String?   @db.VarChar(50)
  created_at  DateTime  @default(now())

  actor_employee Employee? @relation(fields: [actor_id], references: [id])

  @@index([table_name, record_id], map: "idx_audit_logs_table_record")
  @@index([actor_type, actor_id], map: "idx_audit_logs_actor")
  @@index([created_at], map: "idx_audit_logs_created")
}

model Notification {
  id             BigInt    @id @default(autoincrement())
  member_id      BigInt
  title          String    @db.VarChar(255)
  body           String?   @db.Text
  type           String?   @db.VarChar(50)
  reference_id   BigInt?
  reference_type String?   @db.VarChar(50)
  is_read        Boolean   @default(false)
  read_at        DateTime?
  created_at     DateTime  @default(now())

  member Member @relation(fields: [member_id], references: [id])

  @@index([member_id], map: "idx_notifications_member")
  @@index([is_read], map: "idx_notifications_read")
}

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  user_type   UserType
  member_id   BigInt?
  employee_id BigInt?
  full_name   String?   @db.VarChar(255)
  avatar_url  String?   @db.Text
  phone       String?   @db.VarChar(20)
  last_login  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  member   Member?   @relation(fields: [member_id], references: [id])
  employee Employee? @relation(fields: [employee_id], references: [id])
}

model Reservation {
  id               BigInt            @id @default(autoincrement())
  member_id        BigInt?
  branch_id        BigInt
  table_number     String?           @db.VarChar(20)
  reservation_time DateTime
  end_time         DateTime?
  guest_count      Int
  status           ReservationStatus @default(pending)
  note             String?           @db.Text
  created_by       BigInt?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  member              Member?   @relation(fields: [member_id], references: [id])
  branch              Branch    @relation(fields: [branch_id], references: [id])
  created_by_employee Employee? @relation(fields: [created_by], references: [id])

  @@index([branch_id, reservation_time], map: "idx_reservations_branch_time")
  @@index([member_id], map: "idx_reservations_member")
  @@index([status], map: "idx_reservations_status")
}

model Table {
  id           BigInt   @id @default(autoincrement())
  branch_id    BigInt
  table_number String   @db.VarChar(20)
  capacity     Int      @default(4)
  status       String   @default("available") @db.VarChar(20)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  branch Branch @relation(fields: [branch_id], references: [id])

  @@unique([branch_id, table_number], map: "idx_tables_branch_number")
}
